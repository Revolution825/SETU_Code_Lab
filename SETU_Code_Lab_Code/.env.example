# SETU Code Lab — Environment Variables Example
# Copy this file to .env and fill in your values

# Database
DB_NAME=setu_codelab
DB_USER=setu_user
DB_PASSWORD=change_me_to_a_strong_password
DATABASE_URL=postgresql://setu_user:change_me_to_a_strong_password@db:5432/setu_codelab

# Auth
JWT_SECRET=change_me_to_a_long_random_secret
JWT_REFRESH_SECRET=change_me_to_a_different_long_random_secret
JWT_EXPIRY=7d

# Code execution Docker Images
JAVA_EXECUTION_IMAGE=setu-codelab-java-runner
PYTHON_EXECUTION_IMAGE=setu-codelab-python-runner